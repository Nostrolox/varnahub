PORT=4000
NODE_ENV=development

# Production database. Leave blank locally to use data/parking-spots.json.
MONGO_URI=
MONGO_DB_NAME=varna_parking

# Parking SMS draft settings. Configure the official blue zone number before release.
BLUE_ZONE_SMS_NUMBER=
BLUE_ZONE_CODE=ZONE

# Use a long random value in production. It signs anonymous session cookies.
SESSION_SECRET=replace_with_a_long_random_secret

# Comma-separated origins when calling the API directly during development.
CORS_ORIGIN=http://localhost:5173
